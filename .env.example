# TREZZY Content Factory — environment example
# Copy this file to .env and edit values as needed.
# All keys are OPTIONAL for the local MVP — the system runs without them.

# ── Local services ────────────────────────────────────────────────────────
WORKER_HOST=127.0.0.1
WORKER_PORT=8000
API_HOST=127.0.0.1
API_PORT=8001

# ── Optional LLM keys (used only if you swap agents to LLM mode) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional voiceover (ElevenLabs) ───────────────────────────────────────
ELEVENLABS_API_KEY=

# ── Optional social posting (keep empty for local MVP) ────────────────────
INSTAGRAM_GRAPH_TOKEN=
TIKTOK_API_KEY=
YOUTUBE_API_KEY=

# ── Optional automation ──────────────────────────────────────────────────
N8N_WEBHOOK_URL=
